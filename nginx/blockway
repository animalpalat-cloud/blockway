# Blockway Proxy — /etc/nginx/sites-available/blockway
# Handles: daddyproxy.com + *.daddyproxy.com
#
# CORS STRATEGY:
#   Nginx does NOT set any Access-Control headers.
#   Next.js sets them exactly once per response.
#   Nginx uses proxy_hide_header to strip any CORS headers the
#   upstream target site might have sent, preventing duplicates.

upstream nextjs_app {
    server 127.0.0.1:3000;
    keepalive 64;
}

# HTTP → HTTPS redirect
server {
    listen 80;
    listen [::]:80;
    server_name daddyproxy.com www.daddyproxy.com *.daddyproxy.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# ── Root domain (daddyproxy.com / www.daddyproxy.com) ────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name daddyproxy.com www.daddyproxy.com;

    ssl_certificate     /etc/letsencrypt/live/daddyproxy.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/daddyproxy.com/privkey.pem;
    include /etc/nginx/snippets/ssl-params.conf;

    access_log /var/log/nginx/blockway-root.access.log combined;
    error_log  /var/log/nginx/blockway-root.error.log warn;

    # Strip CORS headers from upstream — Next.js sets them once
    proxy_hide_header Access-Control-Allow-Origin;
    proxy_hide_header Access-Control-Allow-Methods;
    proxy_hide_header Access-Control-Allow-Headers;
    proxy_hide_header Access-Control-Allow-Credentials;
    proxy_hide_header Access-Control-Expose-Headers;
    proxy_hide_header Access-Control-Max-Age;
    # Strip security headers that break proxy behaviour
    proxy_hide_header Content-Security-Policy;
    proxy_hide_header Content-Security-Policy-Report-Only;
    proxy_hide_header X-Frame-Options;
    proxy_hide_header Cross-Origin-Opener-Policy;
    proxy_hide_header Cross-Origin-Embedder-Policy;
    proxy_hide_header Cross-Origin-Resource-Policy;

    location /_next/static/ {
        proxy_pass http://nextjs_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    location = /sw.js {
        proxy_pass http://nextjs_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Service-Worker-Allowed "/";
        add_header Content-Type "application/javascript; charset=utf-8";
        access_log off;
    }

    location /proxy {
        proxy_pass http://nextjs_app;
        include /etc/nginx/snippets/proxy-params.conf;
        client_max_body_size 64m;
        proxy_read_timeout 120s;
    }

    location /subdomain-proxy {
        proxy_pass http://nextjs_app;
        include /etc/nginx/snippets/proxy-params.conf;
        client_max_body_size 64m;
        proxy_read_timeout 120s;
    }

    location / {
        proxy_pass http://nextjs_app;
        include /etc/nginx/snippets/proxy-params.conf;
        proxy_read_timeout 60s;
    }
}

# ── Wildcard subdomains (*.daddyproxy.com) ───────────────────────────────────
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name *.daddyproxy.com;

    ssl_certificate     /etc/letsencrypt/live/daddyproxy.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/daddyproxy.com/privkey.pem;
    include /etc/nginx/snippets/ssl-params.conf;

    access_log /var/log/nginx/blockway-subdomain.access.log combined;
    error_log  /var/log/nginx/blockway-subdomain.error.log warn;

    # ── CRITICAL: Strip ALL CORS headers from upstream and from Next.js passthrough
    # This prevents the "multiple values '*, *'" error.
    # Next.js sets these exactly once — Nginx must not add any.
    proxy_hide_header Access-Control-Allow-Origin;
    proxy_hide_header Access-Control-Allow-Methods;
    proxy_hide_header Access-Control-Allow-Headers;
    proxy_hide_header Access-Control-Allow-Credentials;
    proxy_hide_header Access-Control-Expose-Headers;
    proxy_hide_header Access-Control-Max-Age;
    proxy_hide_header Access-Control-Allow-Private-Network;
    # Strip security headers
    proxy_hide_header Content-Security-Policy;
    proxy_hide_header Content-Security-Policy-Report-Only;
    proxy_hide_header X-Frame-Options;
    proxy_hide_header Strict-Transport-Security;
    proxy_hide_header Cross-Origin-Opener-Policy;
    proxy_hide_header Cross-Origin-Embedder-Policy;
    proxy_hide_header Cross-Origin-Resource-Policy;
    proxy_hide_header Origin-Agent-Cluster;

    location = /sw.js {
        proxy_pass http://nextjs_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        add_header Cache-Control "no-cache, no-store, must-revalidate";
        add_header Service-Worker-Allowed "/";
        add_header Content-Type "application/javascript; charset=utf-8";
        access_log off;
    }

    location /_next/static/ {
        proxy_pass http://nextjs_app;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        add_header Cache-Control "public, max-age=31536000, immutable";
        access_log off;
    }

    # ALL subdomain proxy requests — OPTIONS preflight must be handled here too
    location / {
        # Handle OPTIONS preflight explicitly so the browser doesn't wait for Next.js
        if ($request_method = OPTIONS) {
            add_header Access-Control-Allow-Origin  "*" always;
            add_header Access-Control-Allow-Methods "GET, POST, HEAD, PUT, PATCH, DELETE, OPTIONS" always;
            add_header Access-Control-Allow-Headers "Content-Type, Accept, Accept-Language, Accept-Encoding, Authorization, Cookie, Range, X-Requested-With, Origin, Referer, Cache-Control, X-Request-ID, X-Request-Id, X-Client-ID, X-Client-Info, X-Api-Key, X-Api-Version, X-Trace-ID, X-Correlation-ID, X-Session-ID, X-Access-Token, X-Auth-Token, X-CSRF-Token" always;
            add_header Access-Control-Max-Age "86400" always;
            add_header Content-Length "0";
            add_header Content-Type "text/plain";
            return 204;
        }

        proxy_pass http://nextjs_app;
        include /etc/nginx/snippets/proxy-params.conf;
        client_max_body_size 64m;
        proxy_read_timeout 120s;
        proxy_connect_timeout 30s;
        proxy_send_timeout 120s;
    }
}
